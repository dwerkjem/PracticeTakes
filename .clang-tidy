# Static-analysis rules for application-owned C++ code.
#
# The selected checks focus on likely defects and inexpensive modernization.
# Readability suggestions remain warnings, while analyzer, bug-prone, and
# performance findings fail the pre-commit hook.
#
# A few broad-family checks are disabled because they conflict with intentional
# project choices or produce false positives around JUCE APIs and array sizes.
Checks: >
  -*,
  clang-analyzer-*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-misplaced-widening-cast,
  -bugprone-swapped-arguments,
  performance-*,
  -performance-enum-size,
  portability-*,
  -portability-avoid-pragma-once,
  modernize-use-nullptr,
  modernize-use-override,
  readability-braces-around-statements,
  readability-container-size-empty,
  readability-duplicate-include,
  readability-inconsistent-declaration-parameter-name,
  readability-misleading-indentation,
  readability-redundant-*
WarningsAsErrors: >
  clang-analyzer-*,
  bugprone-*,
  performance-*
HeaderFilterRegex: '(^|.*/)src/.*'
FormatStyle: file
SystemHeaders: false
