{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Practice Takes",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/build-and-run.sh",
        "--build-only"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
