{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Practice Takes",
      "type": "shell",
      "command": "${workspaceFolder}/build-and-run.sh",
      "args": ["--build-only"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}