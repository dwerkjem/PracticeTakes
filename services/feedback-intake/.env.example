# Cloudflare credentials. Dashboard-only use needs D1 read/write access.
# configure-cloudflare-access.sh additionally needs Access Apps/Policies Write
# and Workers Scripts Write while it is running; revoke that setup token after use.
CLOUDFLARE_ACCOUNT_ID=replace-with-account-id
CLOUDFLARE_API_TOKEN=replace-with-scoped-api-token
# Temporary setup token; remove this line after configure-cloudflare-access.sh succeeds.
CLOUDFLARE_SETUP_API_TOKEN=
D1_DATABASE_ID=replace-with-d1-database-id

# Local dashboard login. Generate the password with: openssl rand -base64 32
ADMIN_EMAIL=developer@example.com
ADMIN_PASSWORD=replace-with-at-least-16-random-characters

# Hosted Zero Trust dashboard and feedback email delivery.
ACCESS_HOSTNAME=practice-takes-feedback-intake.derekrneilson.workers.dev
FEEDBACK_NOTIFICATION_FROM=feedback@example.com

FEEDBACK_PORT=8787
